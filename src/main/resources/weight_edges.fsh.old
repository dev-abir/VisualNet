#version 430

in float vStrength;
in float vT;

out vec4 fragColor;

uniform float time;

void main() {
//    float s = abs(vStrength) * 25.0;

    float s = clamp(abs(vStrength) * 200.0, 0.0, 1.0);
//if (s < 0.3) discard;
    s = pow(s, 2.0);   // stronger glow for large weights
    // 3. Color: blue → red
    vec3 color = mix(
        vec3(0.2, 0.4, 1.0),   // weak
        vec3(1.0, 0.3, 0.1),   // strong
        s
    );
    float alpha = mix(0.05, 0.9, s);

    fragColor = vec4(color, alpha);
//
//float s = clamp(abs(vStrength) * 25.0, 0.0, 1.0);
//s = pow(s, 1.5);
//
//vec3 color = vec3(1.0, 0.4, 0.1) * s;
//float alpha = s * 0.15;
//
//fragColor = vec4(color, alpha);

}

void gmain() {
//    if (vStrength < 0.004) discard;

//    float pulse = sin(time * 4.0 + vT * 6.28) * 0.5 + 0.5;

//    float alpha = vStrength * pulse;
//float alpha = clamp(vStrength * pulse * 20.0, 0.0, 1.0);
//float alpha = pulse;
float pulse = sin(-time * 4.0 + vT * 6.28318) * 0.5 + 0.5;

float strength = clamp(abs(vStrength) * 30.0, 0.0, 1.0);

float alpha = mix(0.2, 1.0, pulse) * strength;



vec3 color = mix(
        vec3(0.1, 0.2, 0.8),   // low
        vec3(1.0, 0.2, 0.1),   // high
        clamp(vStrength * 5.0, 0.0, 1.0)
    );

//    fragColor = vec4(1, 0.0, 0.0, 1.0);
//     fragColor = vec4(clamp(vStrength * 100.0, 0.0, 1.0), 0.0, 0.0, 1.0);
//    fragColor = vec4(color, alpha);
fragColor = vec4(vec3(pulse), 1.0);

//fragColor = vec4(abs(sin(time)), 0, 0, 1);
}
